# Server Configurations
PORT=5000
NODE_ENV=development

# Database Connection
# If using Docker, this is configured automatically by Docker Compose.
# For local native run, replace with your local Postgres URL.
DATABASE_URL="postgresql://postgres:postgres_secure_pass@localhost:5432/flipkart_tracker?schema=public"

# Scraper Schedule (Standard Cron syntax: Minute Hour Day Month Day-of-Week)
# Default runs every day at 3:00 AM
SCRAPER_CRON_SCHEDULE="0 3 * * *"

# 🔔 Notification Integrations (Optional)

# Discord Webhook Integration
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-id/your-token

# Telegram Bot Integration
# TELEGRAM_BOT_TOKEN=123456789:ABCDefG...
# TELEGRAM_CHAT_ID=987654321

# SMTP Email Integration (Gmail, Mailtrap, Outlook, etc.)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
NOTIFICATION_FROM_EMAIL="no-reply@tracker.io"
