datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum NotificationChannel {
  TELEGRAM
  DISCORD
  EMAIL
}

model Product {
  id           String         @id @default(uuid()) @db.Uuid
  url          String         @db.Text
  platformId   String         @unique @map("platform_id") @db.VarChar(100)
  title        String         @db.VarChar(512)
  imageUrl     String?        @map("image_url") @db.Text
  currentPrice Decimal        @map("current_price") @db.Decimal(12, 2)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  histories    PriceHistory[]
  alerts       Alert[]

  @@index([platformId])
  @@map("products")
}

model PriceHistory {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  price      Decimal  @db.Decimal(12, 2)
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt(sort: Desc)])
  @@map("price_histories")
}

model Alert {
  id                  String              @id @default(uuid()) @db.Uuid
  productId           String              @map("product_id") @db.Uuid
  targetPrice         Decimal             @map("target_price") @db.Decimal(12, 2)
  notificationChannel NotificationChannel @default(TELEGRAM) @map("notification_channel")
  isActive            Boolean             @default(true) @map("is_active")
  lastTriggeredAt     DateTime?           @map("last_triggered_at") @db.Timestamptz
  cooldownHours       Int                 @default(24) @map("cooldown_hours") @db.Integer
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz

  product             Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, targetPrice, notificationChannel])
  @@index([productId, isActive])
  @@map("alerts")
}